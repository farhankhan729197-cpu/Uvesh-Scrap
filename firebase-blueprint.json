{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A customer inquiry for selling an appliance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "applianceType": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "condition": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "location": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["address", "lat", "lng"]
        },
        "pickupDate": { "type": "string", "format": "date" },
        "status": {
          "type": "string",
          "enum": ["Pending", "Picked Up", "Done", "Rejected"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "applianceType", "brand", "location", "pickupDate", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of all appliance sell inquiries."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    }
  }
}
