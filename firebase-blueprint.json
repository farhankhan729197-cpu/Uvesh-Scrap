{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A customer's inquiry for appliance scrap",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "applianceType": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "condition": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "pickupDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "picked_up", "done", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "applianceType", "brand", "address", "pickupDate", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Product inquiries submitted by customers"
    }
  }
}
