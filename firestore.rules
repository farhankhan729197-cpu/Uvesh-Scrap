rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'farhankhan729197@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.role in ['customer', 'admin'] &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role && incoming().email == existing().email) || isAdmin();
    }

    // --- Inquiries Collection ---
    function isValidInquiry(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.applianceType is string && data.applianceType.size() <= 100 &&
             data.brand is string && data.brand.size() <= 100 &&
             data.condition is string && data.condition.size() <= 500 &&
             data.address is string && data.address.size() <= 1000 &&
             data.pickupDate is string && data.pickupDate.size() <= 50 &&
             data.status in ['pending', 'picked_up', 'done', 'rejected'] &&
             (data.model == null || (data.model is string && data.model.size() <= 100)) &&
             (data.photos == null || (data.photos is list && data.photos.size() <= 10)) &&
             (data.location == null || (data.location is map && data.location.lat is number && data.location.lng is number));
    }

    match /inquiries/{inquiryId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidInquiry(incoming()) && 
                    incoming().userId == request.auth.uid && 
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && (
        // Admin can update everything
        isAdmin() ||
        // Customer can only update if it's their inquiry and it's pending
        (isOwner(existing().userId) && existing().status == 'pending' && 
         isValidInquiry(incoming()) && 
         incoming().userId == existing().userId &&
         incoming().createdAt == existing().createdAt &&
         incoming().status == existing().status && // Users can't change status themselves
         incoming().updatedAt == request.time
        )
      );
      
      allow delete: if isAdmin();
    }
  }
}
