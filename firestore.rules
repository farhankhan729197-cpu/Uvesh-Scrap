rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a real app, we'd check a dedicated 'admins' collection or a custom claim
      // For this applet, the user Farhan (as per metadata) will be considered the admin
      // In the absence of a roles collection, we rely on the custom field we set on the user doc
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Helpers
    function isValidInquiry(data) {
      return data.keys().hasAll(['customerId', 'applianceType', 'brand', 'location', 'pickupDate', 'status']) &&
             data.customerId is string &&
             data.applianceType is string &&
             data.brand is string &&
             data.pickupDate is string &&
             data.status in ['Pending', 'Picked Up', 'Done', 'Rejected'] &&
             data.location is map &&
             data.location.address is string;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string;
    }

    // 3. Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber']) && 
                      isValidUserProfile(incoming());
      // Admin can update any user to make them admin etc (if needed)
      allow update: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      // Customers can read their own inquiries
      allow list: if isSignedIn() && resource.data.customerId == request.auth.uid;
      allow get: if isOwner(resource.data.customerId) || isAdmin();
      
      // Anyone signed in can create an inquiry
      allow create: if isSignedIn() && 
                      isValidInquiry(incoming()) && 
                      incoming().customerId == request.auth.uid &&
                      incoming().status == 'Pending'; // Must start as Pending
      
      // Admin can update anything about the inquiry (e.g. status)
      allow update: if isAdmin() && isValidInquiry(incoming());
      
      // Owners can update their own inquiries but ONLY if they are still Pending
      allow update: if isOwner(existing().customerId) && 
                      existing().status == 'Pending' &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['model', 'address', 'pickupDate']) &&
                      isValidInquiry(incoming());
    }
  }
}
